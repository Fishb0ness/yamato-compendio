# SGO Compendio-AI — Variables de entorno
# Copia este archivo como .env.local y rellena los valores

# API Key de Google Gemini (gratuita)
# Obtén la tuya en: https://aistudio.google.com/apikey
# Sin esta variable, la app usa el MockProvider (modo simulación)
VITE_GEMINI_API_KEY=

# Modelo de Gemini a usar (opcional, por defecto: gemini-2.5-flash-lite)
# Modelos disponibles con generateContent en tu cuenta:
#   gemini-2.5-flash-lite   (recomendado, ligero y gratuito)
#   gemini-2.5-flash        (más potente)
#   gemini-2.0-flash-lite   (alternativa si el anterior falla)
#   gemini-3.1-flash-lite-preview
#   gemma-3-27b-it
# Lista completa: curl "https://generativelanguage.googleapis.com/v1beta/models?key=TU_KEY"
VITE_GEMINI_MODEL=gemini-2.5-flash-lite
